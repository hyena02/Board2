<?xml version="1.0" encoding="UTF-8" ?>    
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- 
 Windows -> Preferences -> 검색 : xml -> Xml(Wild Web developer) -> 2개 체크하기
 namespace= "com.green.menus.mapper.MenuMapper" : interface 위치  ->로 찾아간다 -->
<mapper namespace="com.green.menus.mapper.MenuMapper">
	
	<select id="getMenuList"
	        resultType="com.green.menus.dto.MenuDTO">
			
	SELECT     MENU_ID, MENU_NAME, MENU_SEQ
	 FROM      MENUS
	 ORDER BY  MENU_SEQ ASC
	 	
	</select>
  
  <insert id="insertMenu">
  INSERT INTO MENUS (MENU_ID, MENU_NAME, MENU_SEQ)
    VALUES( #{menu_id}, #{menu_name}, #{menu_seq})
  </insert>
  <delete id="deleteMenu">
  DELETE FROM MENUS
  WHERE menu_id = #{menu_id}
  </delete>
</mapper>
